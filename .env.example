# =============================================================================
# Frontend (Vite — exposed to browser, VITE_ prefix required)
# =============================================================================
# Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key_here

# Optional: override API base (default "" = same origin /api on Vercel)
# VITE_API_BASE=

# Local full-stack dev: run `vercel dev` and proxy Vite to it
# VITE_API_PROXY=http://127.0.0.1:3000

# =============================================================================
# Server only (Vercel → Settings → Environment Variables)
# NEVER prefix with VITE_ — these must not reach the browser bundle
# =============================================================================

# Supabase service role — required for storage download after auth check
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_anon_public_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret_here

# Google Gemini — document extraction
GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.5-flash
# EXTRACTION_PROVIDER=gemini
# EXTRACTION_TIMEOUT_MS=55000
# EXTRACTION_MAX_RETRIES=3
# EXTRACTION_MAX_BYTES=15728640
