SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SMOPS_SSH_USER=root            # SSH config alias 'smops' is hardcoded
SMOPS_SNMP_COMMUNITY=public
COLLECTOR_INTERVAL_S=30
COLLECTOR_HEALTH_PORT=8083
LOG_LEVEL=info
# Leave SMOPS_SSH_HOST unset for local fallback mode
# SMOPS_SSH_HOST=smops
