# Telegram bot token from @BotFather. If unset the bot boots in dry-run mode.
TELEGRAM_BOT_TOKEN=

# Google Gemini key + model id.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Supabase (service role only — bot is server-trusted).
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# MCP server (Streamable HTTP transport).
MCP_SERVER_URL=http://127.0.0.1:8082/mcp
MCP_SHARED_SECRET=must-match-mcp-env

# Local health/ready server.
BOT_HEALTH_PORT=8081

# Logging.
LOG_LEVEL=info

# Optional webhook mode. Leave TELEGRAM_WEBHOOK_URL empty to use polling.
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_PORT=8443

# Token bucket per chat (messages / minute).
RATE_LIMIT_PER_MIN=30
